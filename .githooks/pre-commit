#!/bin/bash
# This script runs automatically before every git commit.
# It checks if any staged file is a binary file (e.g., images, PDFs, compiled binaries).
# If a binary file is found, the commit is blocked.

# Log file for pre-commit hook activity
LOG_FILE="$(git rev-parse --show-toplevel)/logs/pre-commit.log"

# Flag to track whether any binary file was found. 0 = no, 1 = yes.
found=0

# "git diff --cached --name-only" lists all file names currently staged for commit.
# "while IFS= read -r file" loops through each file name, one per line.
#   - IFS= prevents leading/trailing whitespace from being trimmed.
#   - -r prevents backslashes from being interpreted as escape characters.
while IFS= read -r file; do

  # "git diff --cached --numstat -- $file" outputs stats for a staged file.
  #   - For text files, it shows numbers like: 10  2  filename
  #   - For binary files, it shows dashes:     -   -  filename
  #
  # "grep -q ^-" checks if the output starts with a dash, meaning it's binary.
  #   - -q means quiet mode (no output, just sets exit code).
  if git diff --cached --numstat -- "$file" | grep -q "^-"; then
    echo "Binary file detected: $file"
    found=1
  fi

done < <(git diff --cached --name-only)

# If any binary file was found, print a help message and exit with code 1.
# Exit code 1 tells git to abort the commit.
# Exit code 0 (the default) would allow the commit to proceed.
if [[ $found -eq 1 ]]; then
  echo "$(date '+%Y-%m-%d %H:%M:%S') BLOCKED - binary files detected" >> "$LOG_FILE"
  echo "Commit blocked: remove binary files from staging area with 'git reset HEAD <file>'"
  exit 1
fi

echo "$(date '+%Y-%m-%d %H:%M:%S') PASSED - no binary files" >> "$LOG_FILE"

# Lint staged Python files with ruff.
# We check the staged content (not working directory) so that:
#   - Unstaged changes don't cause false failures
#   - Staged content with errors can't sneak through

# Get list of staged Python files (Added, Copied, Modified only — skip Deleted).
py_files=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')

if [[ -n "$py_files" ]]; then
    lint_failed=0

    # Loop through each staged Python file.
    while IFS= read -r file; do

        # "git show :$file" outputs the staged version of the file (from the index),
        #   not the working directory version.
        # "ruff check -" tells ruff to read from stdin instead of a file.
        # "--stdin-filename $file" tells ruff the original filename so it can:
        #   - Apply per-file-ignores (e.g. "scratch/**" rules)
        #   - Show the correct filename in error messages
        if ! git show ":$file" | uv run ruff check --stdin-filename "$file" -; then
            lint_failed=1
        fi

    done <<< "$py_files"

    if [[ $lint_failed -eq 1 ]]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') BLOCKED - ruff lint errors" >> "$LOG_FILE"
        echo "Commit blocked: fix ruff lint errors above"
        exit 1
    fi

    echo "$(date '+%Y-%m-%d %H:%M:%S') PASSED - ruff lint clean" >> "$LOG_FILE"
fi
