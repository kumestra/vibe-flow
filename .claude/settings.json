{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(git push)",
      "Bash(git add:*)",
      "Read",
      "Grep"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-py.sh"
          }
        ]
      }
    ]
  }
}
